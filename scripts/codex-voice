#!/usr/bin/env bash
# codex-voice toggle script — push-to-talk dictation via Codex ChatGPT auth.
#
# Press the hotkey once to start recording (overlay pill appears).
# Press again to stop. The overlay stays open showing "Transcribing…"
# while codex-asr processes, then closes before typing the result at
# the cursor via ydotool.
set -uo pipefail

LANG_HINT="${CODEX_VOICE_LANG:-en}"
STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}"
PID_FILE="$STATE_DIR/codex-voice.pid"
WAV_FILE="$STATE_DIR/codex-voice.wav"
OVERLAY_PID_FILE="$STATE_DIR/codex-voice-overlay.pid"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Find overlay.py: check relative to script (dev), then ~/.local/share/codex-voice (installed)
if [ -f "$SCRIPT_DIR/../src/overlay.py" ]; then
  OVERLAY_SCRIPT="$SCRIPT_DIR/../src/overlay.py"
elif [ -f "$HOME/.local/share/codex-voice/overlay.py" ]; then
  OVERLAY_SCRIPT="$HOME/.local/share/codex-voice/overlay.py"
else
  OVERLAY_SCRIPT=""
fi

command -v codex-asr >/dev/null 2>&1 || {
  [ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
}
command -v codex-asr >/dev/null 2>&1 || exit 1

if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; then
  # --- STOP ---
  PID="$(cat "$PID_FILE")"
  kill -INT "$PID" 2>/dev/null || true
  wait "$PID" 2>/dev/null || true
  rm -f "$PID_FILE"

  if [ ! -s "$WAV_FILE" ]; then
    rm -f "$WAV_FILE"
    if [ -f "$OVERLAY_PID_FILE" ]; then
      kill "$(cat "$OVERLAY_PID_FILE")" 2>/dev/null || true
      rm -f "$OVERLAY_PID_FILE"
    fi
    exit 1
  fi

  # Switch overlay to "Transcribing…" state (SIGUSR1)
  if [ -f "$OVERLAY_PID_FILE" ]; then
    kill -USR1 "$(cat "$OVERLAY_PID_FILE")" 2>/dev/null || true
  fi

  # Transcribe while overlay shows "Transcribing…"
  TEXT="$(codex-asr "$WAV_FILE" --language "$LANG_HINT" 2>/dev/null || true)"
  rm -f "$WAV_FILE"

  # Close overlay BEFORE typing to restore focus to the original window
  if [ -f "$OVERLAY_PID_FILE" ]; then
    kill "$(cat "$OVERLAY_PID_FILE")" 2>/dev/null || true
    rm -f "$OVERLAY_PID_FILE"
  fi

  if [ -z "$TEXT" ] || [ "$TEXT" = "..." ]; then
    exit 1
  fi

  # Copy to clipboard
  printf '%s' "$TEXT" | wl-copy 2>/dev/null || true

  # Type at cursor using ydotool (works on GNOME Wayland)
  if command -v ydotool >/dev/null 2>&1; then
    sleep 0.2
    ydotool type --key-delay 12 -- "$TEXT" 2>/dev/null || true
  fi

  printf '%s\n' "$TEXT"
else
  # --- START ---
  rm -f "$WAV_FILE" "$PID_FILE"

  # Launch overlay popup
  if [ -n "$OVERLAY_SCRIPT" ]; then
    python3 "$OVERLAY_SCRIPT" &
    echo "$!" > "$OVERLAY_PID_FILE"
  fi

  # Start recording
  arecord -q -f S16_LE -r 48000 -c 1 "$WAV_FILE" >/dev/null 2>&1 &
  echo "$!" > "$PID_FILE"
fi
