{
  "name": "codex-voice-settings",
  "version": "0.1.0",
  "description": "Complete Codex Voice dictation application with Electron settings",
  "author": {
    "name": "codex-voice contributors",
    "email": "ansanabria@proton.me"
  },
  "homepage": "https://github.com/ansanabria/codex-voice",
  "desktopName": "codex-voice-settings",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on tcp:5173 && electron .\"",
    "build": "cargo build --release --manifest-path ../Cargo.toml && ../packaging/fetch-codex-asr.sh && tsc -p tsconfig.electron.json && vite build && electron-builder --linux deb",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "concurrently": "10.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "shadcn": "^4.13.0",
    "vitest": "4.1.10",
    "wait-on": "9.0.10"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
