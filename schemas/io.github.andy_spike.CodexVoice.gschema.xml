<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.andy_spike.CodexVoice" path="/io/github/andy_spike/CodexVoice/">
    <key name="enabled" type="b">
      <default>true</default>
      <summary>Whether dictation is enabled</summary>
    </key>
    <key name="keybinding" type="as">
      <default>["&lt;Control&gt;&lt;Super&gt;space"]</default>
      <summary>Global dictation shortcut</summary>
    </key>
    <key name="language" type="s">
      <default>'auto'</default>
      <summary>Transcription language hint</summary>
    </key>
    <key name="show-tray-icon" type="b">
      <default>true</default>
      <summary>Show the Codex Voice indicator in the GNOME top bar</summary>
    </key>
  </schema>
</schemalist>
