      <default>'#0e1110eb'</default>
      <summary>Recording pill background colour</summary>
    </key>
    <key name="pill-accent-color" type="s">
      <default>'#32d870'</default>
      <summary>Recording pill accent colour</summary>
    </key>
    <key name="language" type="s">
      <default>'auto'</default>
      <summary>Transcription language hint</summary>
    </key>
  </schema>
</schemalist>
